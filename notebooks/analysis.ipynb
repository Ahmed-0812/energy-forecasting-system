import pandas as pd
import matplotlib.pyplot as plt

# Load dataset
df = pd.read_csv('../data/energy_data.csv')

# Show columns
print(df.columns)

# Rename columns (IMPORTANT – adjust based on your dataset)
df.columns = ['date', 'country', 'temp', 'humidity', 'co2', 'energy', 'renewable', 'industrial', 'other1', 'other2']

# Convert date
df['date'] = pd.to_datetime(df['date'])

# Check data
print(df.head())

# Plot energy usage
plt.figure(figsize=(10,5))
plt.plot(df['date'], df['energy'])
plt.title("Energy Consumption Over Time")
plt.xlabel("Date")
plt.ylabel("Energy")
plt.show()